# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (required for admin API routes)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Admin email - this email gets auto-activated with admin role
# Change this to your admin email address
ADMIN_EMAIL=eduryday@gmail.com

# AI Tutor (required when implementing AI chat feature)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# AI Model (optional, default: claude-sonnet-4-20250514)
# AI_MODEL=claude-sonnet-4-20250514

# AI monthly question limit per student (optional, default: 100)
# AI_MAX_QUESTIONS_PER_MONTH=100
