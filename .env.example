# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (required for admin API routes)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=

# Admin email - this email gets auto-activated with admin role
# Change this to your admin email address
ADMIN_EMAIL=eduryday@gmail.com

# AI Tutor / auto grading via OpenRouter
# Get from: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# AI Model (optional)
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Judge0 code execution (optional, enables code test execution)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=

# AI monthly question limit per student (optional, default: 100)
# AI_MAX_QUESTIONS_PER_MONTH=100

# Error monitoring (optional)
# SENTRY_DSN=
