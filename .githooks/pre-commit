#!/usr/bin/env bash
set -euo pipefail

echo "🔎 pre-commit: lint/typecheck 실행"

if [ -f package.json ]; then
  if npm run | grep -q " lint"; then
    npm run -s lint
  else
    echo "ℹ️ lint 스크립트가 없어 건너뜁니다."
  fi

  if npm run | grep -q " typecheck"; then
    npm run -s typecheck
  else
    echo "ℹ️ typecheck 스크립트가 없어 건너뜁니다."
  fi
else
  echo "ℹ️ package.json 없음. pre-commit 검사 건너뜁니다."
fi
